{
  "name": "@cityssm/street-name-normalize",
  "version": "1.0.0",
  "description": "Takes street names with various abbreviations and attempts to expand them.",
  "keywords": [
    "address",
    "sault-ste-marie",
    "street-names",
    "streets"
  ],
  "homepage": "https://github.com/cityssm/street-name-normalize#readme",
  "bugs": {
    "url": "https://github.com/cityssm/street-name-normalize/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cityssm/street-name-normalize.git"
  },
  "license": "MIT",
  "author": "The Corporation of the City of Sault Ste. Marie",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./ssm.js": "./ssm.js",
    "./substitutions": "./substitutions/index.js"
  },
  "files": [
    "substitutions/*",
    "helpers.*",
    "index.*",
    "ssm.*",
    "types.*"
  ],
  "scripts": {
    "coverage": "c8 --reporter=lcov --reporter=text --reporter=text-summary node --test  \"test/*.test.js\"",
    "test": "node --test \"test/*.test.js\""
  },
  "dependencies": {
    "title-case": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "eslint-config-cityssm": "^41.0.0",
    "prettier-config-cityssm": "^2.1.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
